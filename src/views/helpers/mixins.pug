mixin button(text, type = 'button', mods = [])
	//- text: текст кнопки
	//- type: тип кнопки (button, submit, reset) - по умолчанию 'button'
	//- mods: массив модификаторов для разных стилей
	button.button(
		class=mods.map(m => `button--${m}`).join(' ')
		type=type
	)&attributes(attributes)= text


mixin news-card(item)
	//- item - объект с данными новости
	article.news-card
		a.news-card__link(href=item.link)
			div.news-card__image-wrapper
				img.news-card__image(src=item.img alt=item.title)
			div.news-card__content
				span.news-card__date= item.date
				p.news-card__title= item.title
				p.news-card__text= item.text

mixin input(options = {})
	- 
		const {
			type = 'text',
			name = '',
			id = null ,
			placeholder = ' ',
			required = false,
			maxlength = null,
			minlength = null,
			autocomplete = 'off',
			novalidate = false,
			label = '',
			value = null,
			pattern = null,
			readonly = false,
			disabled = false,
			min = null,
			max = null,
			step = null,
			inputmode = null,
			autofocus = false,
			spellcheck = false,
			describedby = null  // для доступности
		} = options;

	div(class='input')
		label(class='input__wrapper')
			input.input__field(
				type=type
				name=name
				id=id
				placeholder=placeholder
				required=required
				maxlength=maxlength
				minlength=minlength
				autocomplete=autocomplete
				novalidate=novalidate
				value=value
				pattern=pattern
				readonly=readonly
				disabled=disabled
				min=min
				max=max
				step=step
				inputmode=inputmode
				autofocus=autofocus
				spellcheck=spellcheck
				aria-describedby=describedby
			)
			if label
				span.input__label= label